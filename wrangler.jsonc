{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "engenheiro-platform-backend",
  "main": "worker.ts",
  "compatibility_date": "2026-05-12",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    // Public URL of the Node API hosted on Railway.
    "API_ORIGIN": "https://engenheiro-platform-backend-production.up.railway.app"
  }
}
