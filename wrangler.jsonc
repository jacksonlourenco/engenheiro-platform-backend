{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "engenheiro-platform-backend",
  "main": "worker.ts",
  "compatibility_date": "2026-05-12",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    // Base URL of your Docker API (example: "https://api.seu-dominio.com")
    // If not set, API routes will return 500.
    "API_ORIGIN": ""
  }
}
