        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profile\": \"leigo\",\n  \"structural\": {\n    \"area\": 180,\n    \"lajePiso\": \"SIM\",\n    \"lajeCobertura\": \"NÃO\",\n    \"vaoMaior5\": \"NÃO\",\n    \"vaoMaior8\": \"NÃO\",\n    \"piscina\": \"NÃO\",\n    \"balancoMaior1\": \"NÃO\",\n    \"fundacaoRasaEspecial\": \"NÃO\",\n    \"terrenoDeclive\": \"NÃO\",\n    \"elevador\": \"NÃO\",\n    \"muroArrimo\": \"NÃO\",\n    \"memorialDescritivo\": \"SIM\",\n    \"memorialCalculo\": \"SIM\"\n  },\n  \"complementary\": {\n    \"area\": 180,\n    \"abastecimento\": \"CONCESSIONÁRIA\",\n    \"esgotamento\": \"REDE\",\n    \"pluvial\": \"SOLO\",\n    \"normaCondominio\": \"NÃO\",\n    \"contratar\": {\n      \"hidraulico\": \"SIM\",\n      \"sanitario\": \"SIM\",\n      \"pluvial\": \"SIM\",\n      \"eletrico\": \"SIM\",\n      \"incendio\": \"NÃO\"\n    },\n    \"boilerEletrico\": \"NÃO\",\n    \"banheira\": \"NÃO\",\n    \"spa\": \"NÃO\",\n    \"aquecimentoSolar\": \"NÃO\",\n    \"arCondicionadoQtd\": 4,\n    \"equipamentoEspecial\": \"NÃO\",\n    \"gerador\": \"NÃO\",\n    \"subestacao\": \"NÃO\",\n    \"concessionariaPadraoEspecial\": \"NÃO\"\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/budget/calculate", "host": ["{{baseUrl}}"], "path": ["budget", "calculate"] }
      },
      "response": []
    },
    {
      "name": "Budgets - List",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] }
      },
      "response": []
    },
    {
      "name": "Budgets - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profile\": \"leigo\",\n  \"answers\": {\n    \"structural\": {\n      \"area\": 180,\n      \"lajePiso\": \"SIM\",\n      \"lajeCobertura\": \"NÃO\",\n      \"vaoMaior5\": \"NÃO\",\n      \"vaoMaior8\": \"NÃO\",\n      \"piscina\": \"NÃO\",\n      \"balancoMaior1\": \"NÃO\",\n      \"fundacaoRasaEspecial\": \"NÃO\",\n      \"terrenoDeclive\": \"NÃO\",\n      \"elevador\": \"NÃO\",\n      \"muroArrimo\": \"NÃO\",\n      \"memorialDescritivo\": \"SIM\",\n      \"memorialCalculo\": \"SIM\"\n    },\n    \"complementary\": {\n      \"area\": 180,\n      \"abastecimento\": \"CONCESSIONÁRIA\",\n      \"esgotamento\": \"REDE\",\n      \"pluvial\": \"SOLO\",\n      \"normaCondominio\": \"NÃO\",\n      \"contratar\": {\n        \"hidraulico\": \"SIM\",\n        \"sanitario\": \"SIM\",\n        \"pluvial\": \"SIM\",\n        \"eletrico\": \"SIM\",\n        \"incendio\": \"NÃO\"\n      },\n      \"boilerEletrico\": \"NÃO\",\n      \"banheira\": \"NÃO\",\n      \"spa\": \"NÃO\",\n      \"aquecimentoSolar\": \"NÃO\",\n      \"arCondicionadoQtd\": 4,\n      \"equipamentoEspecial\": \"NÃO\",\n      \"gerador\": \"NÃO\",\n      \"subestacao\": \"NÃO\",\n      \"concessionariaPadraoEspecial\": \"NÃO\"\n    }\n  },\n  \"result\": {\n    \"structural\": {\n      \"honorarioTotal\": 1000\n    },\n    \"complementary\": {\n      \"melhorOpcao\": 500\n    },\n    \"totalSuggested\": 1500\n  },\n  \"accepted\": false\n}"
        },
        "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] }
      },
      "response": []
    },
    {
      "name": "Budgets - Accept",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accepted\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/budgets/1", "host": ["{{baseUrl}}"], "path": ["budgets", "1"] }
      },
      "response": []
    },
    {
      "name": "Admin - Landing (Get)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/admin/landing", "host": ["{{baseUrl}}"], "path": ["admin", "landing"] }
      },
      "response": []
    },
    {
      "name": "Admin - Landing (Update)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"home\": {\n    \"headline\": \"Engenharia de qualidade\",\n    \"subtitle\": \"Projetos e obras com acompanhamento completo\",\n    \"ctaText\": \"Quero me cadastrar\",\n    \"ctaLink\": \"/register\",\n    \"image\": \"https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=1200&q=80\"\n  },\n  \"about\": {\n    \"title\": \"Sobre o Engenheiro\",\n    \"content\": \"Texto institucional do engenheiro\",\n    \"images\": [\n      \"https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=900&q=80\"\n    ]\n  },\n  \"services\": {\n    \"title\": \"Servicos\",\n    \"subtitle\": \"Solucoes completas\",\n    \"backgroundImage\": \"https://images.unsplash.com/photo-1489515217757-5fd1be406fef?auto=format&fit=crop&w=1200&q=80\",\n    \"backgroundOpacity\": 0.35,\n    \"cards\": [\n      { \"title\": \"Estrutural\", \"description\": \"Projeto estrutural completo\", \"image\": \"https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=800&q=80\" },\n      { \"title\": \"Hidraulica\", \"description\": \"Instalacoes hidraulicas\", \"image\": \"https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=800&q=80\" },\n      { \"title\": \"Eletrica\", \"description\": \"Projeto eletrico\", \"image\": \"https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=800&q=80\" }\n    ]\n  },\n  \"blog\": {\n    \"title\": \"Blog\",\n    \"videos\": [\n      \"https://www.youtube.com/watch?v=dQw4w9WgXcQ\"\n    ]\n  },\n  \"contacts\": {\n    \"title\": \"Contato\",\n    \"address\": \"Rua Exemplo, 123\",\n    \"phone\": \"(11) 99999-8888\",\n    \"email\": \"contato@engenheiro.com\"\n  }\n}"
        },
        "url": { "raw": "{{baseUrl}}/admin/landing", "host": ["{{baseUrl}}"], "path": ["admin", "landing"] }
      },
      "response": []
    },
    {
      "name": "Admin - Search Users",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/admin/users?search=joao",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "users"],
          "query": [ { "key": "search", "value": "joao" } ]
        }
      },
      "response": []
    },
    {
      "name": "Admin - Toggle Contract",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"contractActive\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/users/{{userId}}/contract",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "users", "{{userId}}", "contract"]
        }
      },
      "response": []
    },
    {
      "name": "Admin - Test Email",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"toEmail\": \"{{adminEmail}}\",\n  \"subject\": \"Teste Mailjet\",\n  \"text\": \"Se voce recebeu este e-mail, o Mailjet esta configurado corretamente.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/admin/test-email", "host": ["{{baseUrl}}"], "path": ["admin", "test-email"] }
      },
      "response": []
    },
    {
      "name": "Admin - Test Email (SendGrid)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"toEmail\": \"{{sendgridTestEmail}}\",\n  \"subject\": \"Teste SendGrid\",\n  \"text\": \"Se voce recebeu este email, o SendGrid esta OK.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/admin/test-email", "host": ["{{baseUrl}}"], "path": ["admin", "test-email"] }
      },
      "response": []
    },
    {
      "name": "Admin - Resend Budget Accepted Email",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/budgets/{{budgetId}}/notify",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "budgets", "{{budgetId}}", "notify"]
        }
      },
      "response": []
    }
  ]
}

