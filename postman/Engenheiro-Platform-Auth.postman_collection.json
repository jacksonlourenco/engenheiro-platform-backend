{
  "info": {
    "name": "Engenheiro Platform - API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection para validar auth, dashboard, orcamento e admin."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "budgetId", "value": "1" },
    { "key": "adminEmail", "value": "" },
    { "key": "sendgridTestEmail", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      },
      "response": []
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Joao da Silva\",\n  \"email\": \"joao@email.com\",\n  \"cpf\": \"12345678901\",\n  \"phone\": \"11999998888\",\n  \"password\": \"123456\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
      },
      "response": []
    },
    {
      "name": "Auth - Login (email ou cpf)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"joao@email.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "if (data.token) {",
              "  pm.collectionVariables.set('token', data.token);",
              "}",
              "if (data.user && data.user.id) {",
              "  pm.collectionVariables.set('userId', data.user.id);",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Auth - Forgot Password",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"joao@email.com\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
      },
      "response": []
    },
    {
      "name": "Auth - Reset Password",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"nova_senha\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
      },
      "response": []
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
      },
      "response": []
    },
    {
      "name": "Auth - Update Profile",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"Rua Exemplo 123\",\n  \"gender\": \"masculino\",\n  \"birthDate\": \"1990-01-01\",\n  \"maritalStatus\": \"solteiro\",\n  \"childrenCount\": 0\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
      },
      "response": []
    },
    {
      "name": "Auth - Admin Me",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/auth/admin/me", "host": ["{{baseUrl}}"], "path": ["auth", "admin", "me"] }
      },
      "response": []
    },
    {
      "name": "Budget - Questions",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/budget/questions",
          "host": ["{{baseUrl}}"],
          "path": ["budget", "questions"]
        }
      },
      "response": []
    },
